#include <libpynq.h>
#include <stdio.h>
#include <stdint.h>
#include <stdbool.h>

#define UART_READY_PIN IO_AR3

#define GRID_MAX_X 99
#define GRID_MAX_Y 99

#define PAYLOAD_LENGTH_BYTES 4u

#define Y_SHIFT       0
#define X_SHIFT       7
#define OBJECT_SHIFT  14

#define COORD_MASK    0x7Fu
#define OBJECT_MASK   0x0Fu

typedef enum {
    OBJ_NONE = 0,

    OBJ_SMALL_RED   = 1,
    OBJ_SMALL_GREEN = 2,
    OBJ_SMALL_BLUE  = 3,
    OBJ_SMALL_BLACK = 4,
    OBJ_SMALL_WHITE = 5,

    OBJ_LARGE_RED   = 6,
    OBJ_LARGE_GREEN = 7,
    OBJ_LARGE_BLUE  = 8,
    OBJ_LARGE_BLACK = 9,
    OBJ_LARGE_WHITE = 10,

    OBJ_CRATER_OR_HOLE = 11,
    OBJ_HILL           = 12
} object_code_t;

static void uart_send_u32_le(uint32_t value) {
    uart_send(UART0, (uint8_t)((value >> 0)  & 0xFF));
    uart_send(UART0, (uint8_t)((value >> 8)  & 0xFF));
    uart_send(UART0, (uint8_t)((value >> 16) & 0xFF));
    uart_send(UART0, (uint8_t)((value >> 24) & 0xFF));
}

static bool wait_for_esp_ready(void) {
    int waited_ms = 0;

    while (gpio_get_level(UART_READY_PIN) == GPIO_LEVEL_LOW && waited_ms < 2000) {
        if (waited_ms == 0) {
            printf("Waiting for ESP32 ready signal on AR3...\n");
        }

        sleep_msec(10);
        waited_ms += 10;
    }

    if (gpio_get_level(UART_READY_PIN) == GPIO_LEVEL_LOW) {
        printf("ESP32 not ready after 2 seconds. Skipping UART send.\n");
        return false;
    }

    return true;
}

static bool pack_object_message(uint8_t x, uint8_t y, object_code_t object, uint32_t *packet_out) {
    if (packet_out == NULL) {
        return false;
    }

    if (x > GRID_MAX_X || y > GRID_MAX_Y) {
        printf("Invalid grid location: x=%u, y=%u. Valid range is 0..99.\n", x, y);
        return false;
    }

    if ((uint8_t)object > 15) {
        printf("Invalid object code: %u. Object must fit in 4 bits, so range is 0..15.\n",
               (uint8_t)object);
        return false;
    }

    uint32_t packet = 0;

    packet |= (((uint32_t)object & OBJECT_MASK) << OBJECT_SHIFT);
    packet |= (((uint32_t)x      & COORD_MASK)  << X_SHIFT);
    packet |= (((uint32_t)y      & COORD_MASK)  << Y_SHIFT);

    *packet_out = packet;
    return true;
}

bool send_object_packet(uint8_t x, uint8_t y, object_code_t object) {
    uint32_t packet;

    if (!pack_object_message(x, y, object, &packet)) {
        return false;
    }

    if (!wait_for_esp_ready()) {
        return false;
    }

    // First 32-bit word: payload length in bytes.
    // The payload is one uint32_t, so this must be 4, not 32.
    uart_send_u32_le(PAYLOAD_LENGTH_BYTES);

    // Second 32-bit word: packed location/object payload.
    uart_send_u32_le(packet);

    printf("UART sent binary packet: length=%u bytes, payload=0x%08X, x=%u, y=%u, object=%u\n",
           PAYLOAD_LENGTH_BYTES,
           packet,
           x,
           y,
           (uint8_t)object);

    return true;
}

static void setup_uart_to_esp(void) {
    // ESP32 ready pin
    switchbox_set_pin(UART_READY_PIN, SWB_GPIO);
    gpio_set_direction(UART_READY_PIN, GPIO_DIR_INPUT);

    // UART0 pins connected to ESP32
    switchbox_set_pin(IO_AR0, SWB_UART0_RX);
    switchbox_set_pin(IO_AR1, SWB_UART0_TX);

    uart_init(UART0);
    uart_reset_fifos(UART0);
}

int main(void) {
    pynq_init();
    switchbox_init();
    buttons_init();

    setup_uart_to_esp();

    printf("Starting binary communication program...\n");
    printf("Press Button 0 to stop.\n");

    while (!get_button_state(BUTTON0)) {
        uint8_t x = 12;
        uint8_t y = 34;
        object_code_t object = OBJ_LARGE_BLUE;

        send_object_packet(x, y, object);

        sleep_msec(500);
    }

    printf("Stopping binary communication program...\n");

    uart_destroy(UART0);
    switchbox_destroy();
    buttons_destroy();
    pynq_destroy();

    return 0;
}
